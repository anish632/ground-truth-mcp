{
	"name": "ground-truth-mcp",
	"version": "0.4.4",
	"mcpName": "io.github.anish632/ground-truth",
	"description": "Free live fact checks for AI agents: endpoints, security headers, pricing, claims, compliance.",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ai",
		"verification",
		"pricing",
		"compliance",
		"security",
		"fact-checking",
		"ground-truth",
		"ai-agents",
		"claim-verification",
		"competitor-analysis",
		"api-validation"
	],
	"author": "Anish Das <anishdasmail@gmail.com>",
	"license": "MIT",
	"homepage": "https://ground-truth-mcp.anishdasmail.workers.dev/",
	"scripts": {
		"start": "wrangler dev",
		"start:glama": "wrangler dev --host 0.0.0.0 --port 3000",
		"start:glama:stdio": "node ./glama-stdio-bridge.mjs",
		"deploy": "wrangler deploy",
		"deploy:xpay": "wrangler deploy --config wrangler.xpay.jsonc",
		"build": "wrangler deploy --dry-run",
		"build:xpay": "wrangler deploy --dry-run --config wrangler.xpay.jsonc",
		"cf-typegen": "wrangler types --env-interface Env",
		"typecheck": "tsc --noEmit",
		"test:usage": "bash ./test-usage-enforcement.sh",
		"test:x402": "node test-x402-payment.mjs"
	},
	"dependencies": {
		"@x402/core": "^2.3.1",
		"@x402/evm": "^2.3.1",
		"@modelcontextprotocol/sdk": "^1.11.0",
		"agents": "^0.4.0",
		"viem": "^2.46.2",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250204.0",
		"typescript": "^5.7.3",
		"wrangler": "^4.0.0"
	}
}
